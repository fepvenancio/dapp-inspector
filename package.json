{
  "name": "dapp-inspector",
  "version": "0.1.0",
  "description": "An MCP server for AI-assisted DApp frontend testing, inspection, and validation",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dapp-inspector": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "build:shims": "node scripts/build-shims.mjs"
  },
  "keywords": ["mcp", "dapp", "testing", "blockchain", "wallet", "playwright", "starknet", "evm", "solana"],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "playwright": "^1.50.0",
    "zod": "^3.24.0",
    "commander": "^13.1.0",
    "starknet": "^6.23.1",
    "viem": "^2.23.0",
    "@solana/web3.js": "^1.98.0",
    "@solana/spl-token": "^0.4.12",
    "bs58": "^6.0.0",
    "chalk": "^5.4.1",
    "nanoid": "^5.1.2"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.4.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.12.0",
    "esbuild": "^0.24.0"
  }
}
